{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "onyx",
      "camelcase": "Onyx",
      "title": "Onyx",
      "scope": "source.onyx",
      "file-types": [
        "nyx"
      ],
      "injection-regex": "^onyx$",
      "class-name": "TreeSitterOnyx"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Grammar for the code generation of Onyx",
    "authors": [
      {
        "name": "ak-elements",
        "email": "akelements.dev@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-onyx",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}